{
  "redirects": [
    {
      "source": "/pricing",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/australia/:path*",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/uk/:path*",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/canada/:path*",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/category/:path*",
      "destination": "/",
      "statusCode": 301
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
